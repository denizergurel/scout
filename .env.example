# Scout — Environment

# --- LLM provider selection ---
# Choose one: claude (default), gemini, openai
LLM_PROVIDER=claude

# --- Claude (default) ---
# No API key needed. Uses the local `claude` CLI (npm: @anthropic-ai/claude-code)
# authed against your Claude Pro/Max subscription. Billing goes against the subscription.
# Override the CLI path if needed:
# CLAUDE_BIN=/opt/homebrew/bin/claude

# --- Gemini ---
# Set LLM_PROVIDER=gemini and supply a key from https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-pro

# --- OpenAI / ChatGPT ---
# Set LLM_PROVIDER=openai and supply a key from https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
